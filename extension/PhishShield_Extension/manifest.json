{
  "manifest_version": 2,
  "name": "PhishShield",
  "version": "1.0.3",
  "description": "Detect if the current tab is a phishing website.",
  "browser_specific_settings": {
    "gecko": {
      "id": "phishshield-extension-v2@hackathon.local",
      "data_collection_permissions": {
        "required": ["browsingActivity"]
      }
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "webNavigation",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "background": {
    "scripts": ["libs/ethers.umd.min.js", "background.js"],
    "persistent": false
  }
}